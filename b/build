#!/bin/bash
# Docker-only build wrapper. Runs the given command inside the ty-builder
# container; the host needs only Docker + git.
#
#   b/build make prod-images-skip-tests     # full build + unit tests, no e2e
#   b/build b/check                         # fast PR-check tier
#   b/build bash                            # interactive shell
#
# PATH-IDENTITY CONSTRAINT (do not "fix" this): the container talks to the
# HOST docker daemon through the mounted socket, so every path docker compose
# resolves (bind-mount sources like ./:/opt/talkyard/app/) must be a valid
# HOST path. Therefore the repo is mounted at its own host absolute path and
# the workdir is set to the same path.
#
# Flags (must come first):
#   --isolated        run against a PRIVATE docker daemon (docker:dind) instead
#                     of the host daemon: host ports stay free, the prod
#                     build's no-unrelated-containers check always passes.
#                     First run is cold (own image cache, kept in a volume).
#   --clean-isolated  remove the dind container + its cache volume, and exit.
#   --arch <arch>     build the RUNTIME images for another CPU arch, e.g.
#                     `--arch arm64`: exports TY_TARGET_ARCH, which the prod
#                     build scripts scope to the runtime-image builds only
#                     (gulp/sbt and the dev images stay native — their output
#                     is arch-independent). Foreign-arch layers build via
#                     qemu/binfmt: install qemu-user-static on the box once.
#
# Env knobs:
#   TY_BUILD_HEAP_MB   sbt/Play heap for test runs (default: s/d-cli's logic,
#                      min 5120; prod builds use 8192)
#   TY_REUSE_APP_DIST  skip sbt test+dist when target/universal/*.zip already
#                      exists — for a second-arch pass right after a native
#                      build (passed through into the builder).
set -euo pipefail

cd "$(dirname "$0")/.."
repo="$(pwd)"

isolated=""
target_arch="${TY_TARGET_ARCH:-}"
while :; do
  case "${1:-}" in
    --isolated)
      isolated=1; shift ;;
    --clean-isolated)
      # Honor a preceding --arch: clean that arch's dind, not the default one.
      if [ -n "$target_arch" ] && [ -z "${TY_DIND_NAME:-}" ]; then
        export TY_DIND_NAME="ty-dind-$target_arch"
        export TY_DIND_NET="ty-build-net-$target_arch"
        export TY_DIND_VOL="ty-dind-$target_arch-cache"
      fi
      . b/impl/dind-lib.sh
      clean_dind
      exit 0 ;;
    --arch)
      target_arch="${2:?b/build: --arch needs a value, e.g.: --arch arm64}"
      shift 2 ;;
    *)
      break ;;
  esac
done

sock=/var/run/docker.sock
if [ ! -S "$sock" ]; then
  echo "b/build: no docker socket at $sock — install/start Docker first." >&2
  exit 1
fi
if [ "$(id -u)" -eq 0 ]; then
  echo "b/build: don't run as root (the build scripts refuse root)." >&2
  exit 1
fi

# TY_BUILDER_IMG: use a prebuilt builder image (e.g. pulled via
# b/pull-build-images) instead of building locally.
builder_img="${TY_BUILDER_IMG:-ty-builder}"
if [ -z "${TY_BUILDER_IMG:-}" ]; then
  echo "b/build: building ty-builder image ..." >&2
  docker build -t ty-builder "$repo/images/builder" >&2
fi

tty_flag=""
if [ -t 0 ] && [ -t 1 ]; then tty_flag="-t"; fi

heap_env=()
if [ -n "${TY_BUILD_HEAP_MB:-}" ]; then
  heap_env=(-e "PLAY_HEAP_MEMORY_MB=${TY_BUILD_HEAP_MB}")
fi
if [ -n "$target_arch" ]; then
  heap_env+=(-e "TY_TARGET_ARCH=$target_arch")
fi
if [ -n "${TY_REUSE_APP_DIST:-}" ]; then
  heap_env+=(-e "TY_REUSE_APP_DIST=$TY_REUSE_APP_DIST")
fi

if [ -n "$isolated" ]; then
  if [ -n "$target_arch" ] && [ -z "${TY_DIND_NAME:-}" ]; then
    # Cross-arch builds get their OWN dind: image caches and the :latest
    # tags are per-daemon, and sharing a daemon would overwrite the native
    # :latest tags that other runs (e2e stacks, sbt dependency services)
    # boot containers from.
    export TY_DIND_NAME="ty-dind-$target_arch"
    export TY_DIND_NET="ty-build-net-$target_arch"
    export TY_DIND_VOL="ty-dind-$target_arch-cache"
  fi
  . b/impl/dind-lib.sh
  ensure_dind "$repo"
  # Talk to the private daemon over the bridge net — no socket mount, so
  # nothing here can touch the host daemon.
  exec docker run --rm -i $tty_flag \
    -v "$repo":"$repo" \
    -w "$repo" \
    --network "$TY_DIND_NET" \
    -e "DOCKER_HOST=$TY_DIND_DOCKER_HOST" \
    -e "HOST_UID=$(id -u)" \
    -e "TY_NONINTERACTIVE=${TY_NONINTERACTIVE:-1}" \
    -e "HOST_GID=$(id -g)" \
    "${heap_env[@]}" \
    ty-builder "$@"
fi

exec docker run --rm -i $tty_flag \
  -v "$repo":"$repo" \
  -w "$repo" \
  -v "$sock":"$sock" \
  -e "HOST_UID=$(id -u)" \
  -e "TY_NONINTERACTIVE=${TY_NONINTERACTIVE:-1}" \
  -e "HOST_GID=$(id -g)" \
  -e "DOCKER_GID=$(stat -c %g "$sock")" \
  "${heap_env[@]}" \
  "$builder_img" "$@"

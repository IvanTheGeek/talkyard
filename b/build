#!/bin/bash
# Docker-only build wrapper. Runs the given command inside the ty-builder
# container; the host needs only Docker + git.
#
#   b/build make prod-images-skip-tests     # full build + unit tests, no e2e
#   b/build b/check                         # fast PR-check tier
#   b/build bash                            # interactive shell
#
# PATH-IDENTITY CONSTRAINT (do not "fix" this): the container talks to the
# HOST docker daemon through the mounted socket, so every path docker compose
# resolves (bind-mount sources like ./:/opt/talkyard/app/) must be a valid
# HOST path. Therefore the repo is mounted at its own host absolute path and
# the workdir is set to the same path.
#
# Flags (must come first):
#   --isolated        run against a PRIVATE docker daemon (docker:dind) instead
#                     of the host daemon: host ports stay free, the prod
#                     build's no-unrelated-containers check always passes.
#                     First run is cold (own image cache, kept in a volume).
#   --clean-isolated  remove the dind container + its cache volume, and exit.
#
# Env knobs:
#   TY_BUILD_HEAP_MB   sbt/Play heap for test runs (default: s/d-cli's logic,
#                      min 5120; prod builds use 8192)
set -euo pipefail

cd "$(dirname "$0")/.."
repo="$(pwd)"

isolated=""
if [ "${1:-}" = "--isolated" ]; then
  isolated=1; shift
elif [ "${1:-}" = "--clean-isolated" ]; then
  . b/impl/dind-lib.sh
  clean_dind
  exit 0
fi

sock=/var/run/docker.sock
if [ ! -S "$sock" ]; then
  echo "b/build: no docker socket at $sock — install/start Docker first." >&2
  exit 1
fi
if [ "$(id -u)" -eq 0 ]; then
  echo "b/build: don't run as root (the build scripts refuse root)." >&2
  exit 1
fi

echo "b/build: building ty-builder image ..." >&2
docker build -t ty-builder "$repo/images/builder" >&2

tty_flag=""
if [ -t 0 ] && [ -t 1 ]; then tty_flag="-t"; fi

heap_env=()
if [ -n "${TY_BUILD_HEAP_MB:-}" ]; then
  heap_env=(-e "PLAY_HEAP_MEMORY_MB=${TY_BUILD_HEAP_MB}")
fi

if [ -n "$isolated" ]; then
  . b/impl/dind-lib.sh
  ensure_dind "$repo"
  # Talk to the private daemon over the bridge net — no socket mount, so
  # nothing here can touch the host daemon.
  exec docker run --rm -i $tty_flag \
    -v "$repo":"$repo" \
    -w "$repo" \
    --network "$TY_DIND_NET" \
    -e "DOCKER_HOST=$TY_DIND_DOCKER_HOST" \
    -e "HOST_UID=$(id -u)" \
    -e "HOST_GID=$(id -g)" \
    "${heap_env[@]}" \
    ty-builder "$@"
fi

exec docker run --rm -i $tty_flag \
  -v "$repo":"$repo" \
  -w "$repo" \
  -v "$sock":"$sock" \
  -e "HOST_UID=$(id -u)" \
  -e "HOST_GID=$(id -g)" \
  -e "DOCKER_GID=$(stat -c %g "$sock")" \
  "${heap_env[@]}" \
  ty-builder "$@"

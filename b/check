#!/bin/bash
# Fast PR-check tier: everything a pull request must not break, nothing more.
#   - git submodules present
#   - vendored node_modules present (container-pnpm fallback)
#   - dev images built (compose build; cached = no-op)
#   - all client TypeScript/Stylus compiles (debug asset bundles, gulp in the
#     nodejs container)
#   - Scala compiles and the unit/app test suite runs (sbt in the app
#     container; the DB etc start automatically via compose depends_on)
#
# No minified release bundles, no image builds beyond the dev ones, no sbt
# dist, no e2e — that is `make prod-images` territory. Intended invocation:
#   b/build b/check          (add --isolated for a private daemon)
# Emits a per-stage timing/result table on exit (b/impl/stages-lib.sh),
# also written to target/ty-build-summary.txt for CI artifacts.
set -o pipefail

cd "$(dirname "$0")/.."
. b/impl/stages-lib.sh
ty_stages_init

ty_stage "no pull_request-triggered Forgejo workflows"
# SECURITY INVARIANT: the Forgejo repo is PUBLIC and its runner is host-mode
# (jobs run directly on the box, full docker access). A pull_request trigger
# would let a stranger's fork PR execute code there. Keep triggers to
# cron/dispatch/push (writer-only) — fail loudly if anyone adds one.
if grep -lE '^[[:space:]]*(pull_request|pull_request_target)[[:space:]]*:' \
     .forgejo/workflows/*.yml 2>/dev/null; then
  echo "b/check: pull_request trigger found in .forgejo/workflows/ (files above)."
  echo "That would run stranger-controlled code on the host-mode runner. Refusing."
  exit 1
fi

ty_stage "git submodules"
make git-subm-init-upd || exit $?

ty_stage "node_modules (vendored)"
make node_modules || exit $?

ty_stage "dev images (compose build — no-op when cached)"
# 'docker compose run' does NOT build missing images for services that also
# have an 'image:' name — on a fresh daemon it tries to PULL debiki/*-dev,
# which only exist locally. Build explicitly: nodejs (gulp), app (sbt), and
# app's depends_on services.
sudo docker compose build nodejs app rendr cache rdb search egressp || exit $?

ty_stage "debug asset bundles (client TS/CSS, gulp in container)"
make debug_asset_bundles || exit $?

ty_stage "sbt compile + unit/app tests (in app container)"
# PLAY_HEAP_MEMORY_MB: honored by s/d-cli if set (b/build forwards
# TY_BUILD_HEAP_MB into it); otherwise s/d-cli defaults with a 5120 MB floor.
s/d-cli test < /dev/null
sbt_rc=$?

if [ $sbt_rc -eq 0 ]; then
  echo "b/check: OK"
else
  echo "b/check: sbt test exited $sbt_rc"
  echo "NOTE: the suite is expected green on main (verified 2026-07-18,"
  echo "996 passed / 0 failed). If render/Nashorn specs fail, check that the"
  echo "debug asset bundles built — those specs need server-bundle.js, which"
  echo "is why this script builds bundles BEFORE running the tests."
fi
exit $sbt_rc
